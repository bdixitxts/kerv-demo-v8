{
  "name": "kerv-interactive-video-demo",
  "version": "1.0.0",
  "description": "KERV-style AI-powered interactive video demo platform",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start:backend": "npm run start --prefix backend",
    "build:frontend": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend -- --host\""
}
